{
  "name": "datafusion-world-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:critical": "playwright test --project=critical",
    "test:e2e:features": "playwright test --project=features",
    "test:e2e:integration": "playwright test --project=integration",
    "test:e2e:performance": "playwright test --project=performance",
    "test:e2e:edge-cases": "playwright test --project=edge-cases",
    "test:e2e:legacy": "playwright test --project=legacy",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@faker-js/faker": "^10.2.0",
    "phaser": "^3.70.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
